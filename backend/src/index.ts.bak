// ─── QR GENERATION ──────────────────────────────────────────

// Generate offline QR with NaCl encryption
app.post('/api/qr/generate', (req: Request, res: Response) => {
  const { patientId } = req.body as { patientId: string };
  const patient = patients.find(p => p.patientId === patientId);

  if (!patient) {
    res.status(404).json({ error: 'Patient not found' });
    return;
  }

  // Run risk assessment
  const riskAssessment = assessPatientRisk({
    dateOfBirth: patient.dateOfBirth,
    medications: patient.medications,
    allergies: patient.allergies,
    conditions: patient.conditions,
    implants: patient.implants,
  });

  // Build AI summary
  const medicalSummary = buildMedicalSummary(patient);

  const payload = {
    patientId: patient.patientId,
    qrTokenId: uuidv4(),
    name: patient.name,
    dateOfBirth: patient.dateOfBirth,
    bloodType: patient.bloodType,
    emergencyContacts: patient.emergencyContacts,
    medications: patient.medications,
    allergies: patient.allergies,
    conditions: patient.conditions,
    implants: patient.implants,
    medicalSummary,
    riskAssessment,
    lastUpdated: Date.now(),
    expiryTime: Date.now() + (30 * 24 * 60 * 60 * 1000), // 30 days
    encryptionVersion: 'v1',
    accessLog: [],
    consentLevel: 'FULL',
  };

  // Encrypt with patient's public key
  const keyPair = demoKeyPairs[patientId as keyof typeof demoKeyPairs];
  let encryptedPayload: string;

  if (keyPair) {
    encryptedPayload = encryptPayload(JSON.stringify(payload), keyPair.publicKey);
  } else {
    // Fallback: base64 encode
    encryptedPayload = Buffer.from(JSON.stringify(payload)).toString('base64');
  }

  res.json({
    encryptedPayload,
    qrTokenId: payload.qrTokenId,
    expiryTime: payload.expiryTime,
    dataSize: encryptedPayload.length,
    // Include raw + secret key for demo/testing (in production, secret key stays on device)
    raw: payload,
    _demo_secretKey: keyPair ? keyPairToHex(keyPair).secretKey : null,
  });
});

